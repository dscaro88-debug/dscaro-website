# DS CARO lead routing
#
# Required for email notifications through Resend.
# Vercel production env should set this when the domain/email provider is ready.
RESEND_API_KEY=

# Optional. Defaults to dscaro88@gmail.com when omitted.
LEAD_NOTIFY_EMAIL=dscaro88@gmail.com

# Optional. Use a verified Resend sender when available.
# Fallback is Resend's onboarding sender, which may be limited by account rules.
LEAD_FROM_EMAIL="DS CARO Website <onboarding@resend.dev>"

# Optional. Use this to send every lead to a Google Sheet / CRM / automation webhook.
LEAD_WEBHOOK_URL=

# Optional but recommended. GA4 measurement ID for traffic + conversion tracking.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional. GSC meta verification value if DNS verification is not used.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional. Bing Webmaster Tools meta verification value if DNS verification is not used.
NEXT_PUBLIC_BING_SITE_VERIFICATION=
